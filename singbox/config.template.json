{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      { "tag": "google", "address": "tls://8.8.8.8" },
      { "tag": "local",  "address": "local", "detour": "direct" }
    ],
    "rules": [
      { "domain_suffix": ["tv.hohai.eu.org"], "server": "google" }
    ],
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "sniff": true,
      "set_system_proxy": false
    }
  ],
  "outbounds": [
    { "type": "selector", "tag": "proxy",  "outbounds": ["urltest"], "default": "urltest" },
    { "type": "urltest",  "tag": "urltest",
      "outbounds": ["__PLACEHOLDER__"],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50,
      "idle_timeout": "30m"
    },
    { "type": "direct",   "tag": "direct" },
    { "type": "block",    "tag": "block"  },
    { "type": "dns",      "tag": "dns-out" }
  ],
  "route": {
    "rules": [
      { "protocol": "dns", "outbound": "dns-out" }
    ],
    "final": "proxy",
    "auto_detect_interface": false
  },
  "experimental": {
    "cache_file": { "enabled": false }
  }
}
