HOHAI_UN=your_username
HOHAI_PW=your_password
HEADLESS=true
STRICT_PROXY=true

# Local sing-box mixed inbound. The workflow sets this automatically;
# only set it manually when running checkin.py outside Actions.
HTTP_PROXY_URL=http://127.0.0.1:7890

# Optional Telegram notify
HOHAI_TGTK=
HOHAI_TGID=

# Only for tools/render_singbox.py — JSON array of authenticated SOCKS5 nodes.
# Stored as a single GitHub Actions secret (PROXY_NODES_JSON) in production.
# PROXY_NODES_JSON=[{"tag":"hk-01","server":"1.2.3.4","port":1080,"username":"u","password":"p"}]
